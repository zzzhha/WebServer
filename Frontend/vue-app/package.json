{
  "name": "vue-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "check": "vue-tsc -b",
    "lint": "eslint . --ext .ts,.vue",
    "lint:fix": "eslint . --ext .ts,.vue --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "node scripts/smoke-api.mjs",
    "test:e2e": "playwright test",
    "perf:bundle": "vite build && node scripts/check-bundle.mjs"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.511.0",
    "pinia": "^2.1.7",
    "tailwind-merge": "^3.3.0",
    "vue": "^3.4.15",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.1",
    "@types/node": "^22.15.30",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vue/test-utils": "^2.4.6",
    "@vue/runtime-dom": "^3.4.15",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.1",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.3.3",
    "unplugin-vue-dev-locator": "^1.0.0",
    "vite": "^5.0.12",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vitest": "^1.6.0",
    "vue-tsc": "^1.8.27"
  }
}
